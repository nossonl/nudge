{
  "id": "reinforceclaw-feedback",
  "name": "ReinforceClaw Feedback",
  "description": "Rate AI responses good/bad and train your local model via RL",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "reinforceclawHost": { "type": "string", "default": "http://127.0.0.1:8420" },
      "reinforceclawSecret": { "type": "string", "default": "" },
      "reinforceclawFeedbackMode": {
        "type": "string",
        "enum": ["slash_reactions_prompt", "slash_and_reactions", "slash_only"],
        "default": "slash_reactions_prompt"
      },
      "reinforceclawRaterUsers": { "type": "string", "default": "" },
      "reinforceclawAllowAdminCommands": { "type": "boolean", "default": false },
      "reinforceclawAdminUsers": { "type": "string", "default": "" }
    }
  },
  "uiHints": {
    "reinforceclawSecret": { "sensitive": true }
  }
}
